!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage
.pytest_cache/
htmlcov/
.tox/
.nox/

# Next.js
/.next/
/out/

# Production / bundlers
/build
dist/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
*.egg
.venv/
venv/
env/
.mypy_cache/
.ruff_cache/

# Misc
.DS_Store
Thumbs.db
*.pem
*.swp
*.swo

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment (keep .env.example committed if you add one)
.env
.env.*
!.env.example

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Terraform (commit .terraform.lock.hcl for reproducible applies)
*.tfstate
*.tfstate.*
.terraform/
terraform/ci_backend.tf
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
terraform.tfvars
*.auto.tfvars
*.auto.tfvars.json
*.tfplan
*.tfplan.*

# IDE / local tooling
.idea/
.vscode/
.cursor/
